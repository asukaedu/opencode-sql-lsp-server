{
  "name": "vscode-opencode-sql-lsp-wrapper",
  "displayName": "OpenCode SQL LSP",
  "description": "Minimal VS Code wrapper for the opencode-sql-lsp stdio server",
  "version": "0.1.0",
  "publisher": "asukaedu",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/asukaedu/opencode-sql-lsp-server.git"
  },
  "homepage": "https://github.com/asukaedu/opencode-sql-lsp-server/tree/main/extensions/vscode-opencode-sql-lsp-wrapper",
  "bugs": {
    "url": "https://github.com/asukaedu/opencode-sql-lsp-server/issues"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "sql",
    "lsp",
    "language-server",
    "opencode",
    "sqlfluff"
  ],
  "extensionKind": [
    "workspace"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:sql"
  ],
  "contributes": {
    "configuration": {
      "title": "OpenCode SQL LSP",
      "properties": {
        "opencodeSql.serverPath": {
          "type": "string",
          "default": "opencode-sql-lsp",
          "description": "Command or absolute path used to launch the SQL language server."
        },
        "opencodeSql.serverArgs": {
          "type": "array",
          "default": [
            "--stdio"
          ],
          "items": {
            "type": "string"
          },
          "description": "Arguments passed to the SQL language server command."
        }
      }
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p ./",
    "bundle": "esbuild ./src/extension.ts --bundle --platform=node --format=cjs --external:vscode --outfile=out/extension.js --sourcemap",
    "compile": "npm run typecheck && npm run bundle",
    "vscode:prepublish": "npm run compile",
    "package": "node -e \"require('fs').mkdirSync('dist',{recursive:true})\" && vsce package --no-dependencies --out dist/opencode-sql-lsp-wrapper.vsix",
    "verify": "npm run compile && npm run package"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "@types/vscode": "^1.100.0",
    "@vscode/vsce": "^3.6.2",
    "esbuild": "^0.25.3",
    "vscode-languageclient": "^9.0.1",
    "typescript": "^5.8.3"
  }
}
